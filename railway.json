{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "uvicorn api:app --host 0.0.0.0 --port $PORT",
    "restartPolicyMaxRetries": 5,
    "healthchecks": {
      "enabled": true,
      "interval": 10,
      "startTimeout": 60
    }
  },
  "plugins": [
    "python",
    "nodejs"
  ]
}
